# Copy this file to .env and fill in real values. NEVER commit .env.

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project URL is safe to share (appears in API responses).
# Keys MUST be kept secret — never commit, never paste anywhere public.
SUPABASE_URL=https://jxsxzbuumglmpjtevkpp.supabase.co
SUPABASE_ANON_KEY=                # paste after rotation (Settings → API → Reset)
SUPABASE_SERVICE_ROLE_KEY=        # paste after rotation; bypasses RLS, scrapers only

# Optional: direct Postgres URL for migrations (Settings → Database → Connection string)
# Use the "Transaction" pooler URL (port 6543) for compatibility with most clients
SUPABASE_DB_URL=                  # postgresql://postgres.jxsxzbuumglmpjtevkpp:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ─── Dhan API ─────────────────────────────────────────────────────────────────
# Get from https://dhan.co/api → My Profile → Access Token
# Token expires every 24h for non-trading accounts; longer for trading accounts
DHAN_CLIENT_ID=your-client-id
DHAN_ACCESS_TOKEN=your-access-token

# ─── Rate Limits (requests per second per source) ─────────────────────────────
DHAN_RATE_LIMIT_RPS=2.0
MFAPI_RATE_LIMIT_RPS=5.0
RUPEEVEST_RATE_LIMIT_RPS=1.0
TRENDLYNE_RATE_LIMIT_RPS=0.3
SCAN360_RATE_LIMIT_RPS=2.0

# ─── Circuit Breaker ──────────────────────────────────────────────────────────
CIRCUIT_BREAKER_THRESHOLD=5

# ─── Run Metadata ─────────────────────────────────────────────────────────────
# Set automatically by GitHub Actions; default 'manual' for local runs
TRIGGERED_BY=manual

# ─── Optional: Alerting ───────────────────────────────────────────────────────
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
